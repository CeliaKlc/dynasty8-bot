# ============================
# DYNASTY 8 - CONFIGURATION
# ============================

# Token de ton bot Discord (depuis le Discord Developer Portal)
TOKEN=TON_TOKEN_ICI

# ID de l'application Discord
CLIENT_ID=ID_DE_L_APPLICATION

# ID de ton serveur Discord
GUILD_ID=ID_DE_TON_SERVEUR

# ID du canal pour les logs internes (notes, actions agents)
CHANNEL_LOGS_ID=ID_DU_CANAL_LOGS

# URI de connexion MongoDB Atlas (pour les rendez-vous)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# ID du rôle à mentionner dans les annonces immobilières (notifications-LBC)
ROLE_NOTIFICATIONS_LBC_ID=ID_DU_ROLE_NOTIFICATIONS_LBC
