# ============================
# DYNASTY 8 - CONFIGURATION
# ============================

# Token de ton bot Discord (depuis le Discord Developer Portal)
TOKEN=TON_TOKEN_ICI

# ID de ton serveur Discord
GUILD_ID=ID_DE_TON_SERVEUR

# ID du canal où les annonces immobilières seront postées
CHANNEL_ANNONCES_ID=ID_DU_CANAL_ANNONCES

# ID du canal où les tickets seront créés (catégorie)
CATEGORIE_TICKETS_ID=ID_DE_LA_CATEGORIE_TICKETS

# ID du canal où le panel de tickets sera affiché
CHANNEL_TICKETS_ID=ID_DU_CANAL_TICKETS

# ID du rôle "Agente" (sera pingé à chaque ticket)
ROLE_AGENTE_ID=ID_DU_ROLE_AGENTE

# ID du canal pour les logs (optionnel)
CHANNEL_LOGS_ID=ID_DU_CANAL_LOGS

# URI de connexion MongoDB Atlas (pour les rendez-vous)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
